{
  "name": "motoverse",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/staff-app",
    "apps/customer-app",
    "backend",
    "packages/shared"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
